generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnonymousSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("anonymous_sessions")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  name          String   @default("")
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  sessions      Session[]
  accounts      Account[]
  careerProfile CareerProfile?
  applications  CvApplication[]
  agentRuns     AgentRun[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

model CareerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  rawCvText     String   @map("raw_cv_text") @db.Text
  rawCvFileName String?  @map("raw_cv_file_name")
  profileJson   Json     @map("profile_json")
  seniority     String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications CvApplication[]

  @@index([userId])
  @@map("career_profiles")
}

model CvApplication {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  careerProfileId String   @map("career_profile_id")
  jobText         String   @map("job_text") @db.Text
  jobAnalysisJson Json?    @map("job_analysis_json")
  matchJson       Json?    @map("match_json")
  questionsJson   Json?    @map("questions_json")
  answersJson     Json?    @map("answers_json")
  extraNotes      String?  @map("extra_notes") @db.Text
  matchScore      Int?     @map("match_score")
  status          String   @default("questions_ready")
  warningJson     Json?    @map("warning_json")
  error           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerProfile CareerProfile @relation(fields: [careerProfileId], references: [id], onDelete: Cascade)
  draft         CvDraft?
  agentRuns     AgentRun[]

  @@index([userId, createdAt])
  @@index([careerProfileId])
  @@index([status])
  @@map("cv_applications")
}

model CvDraft {
  id                String   @id @default(cuid())
  applicationId     String   @unique @map("application_id")
  structuredCvJson  Json     @map("structured_cv_json")
  sanitizedCvJson   Json     @map("sanitized_cv_json")
  html              String   @db.Text
  pdfBytes          Bytes    @map("pdf_bytes")
  renderMetricsJson Json     @map("render_metrics_json")
  createdAt         DateTime @default(now()) @map("created_at")

  application CvApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("cv_drafts")
}

model AgentRun {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  applicationId     String?  @map("application_id")
  step              String
  model             String
  status            String
  inputTokens       Int?     @map("input_tokens")
  cachedInputTokens Int?     @map("cached_input_tokens")
  outputTokens      Int?     @map("output_tokens")
  costUsd           Decimal? @map("cost_usd") @db.Decimal(10, 6)
  durationMs        Int?     @map("duration_ms")
  error             String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  application CvApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([applicationId])
  @@index([step, createdAt])
  @@map("agent_runs")
}
