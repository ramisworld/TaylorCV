generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  started
  job_added
  candidate_added
  evidence_ready
  questions_ready
  answers_added
  strategy_failed
  strategy_ready
  draft_failed
  draft_ready
  cv_ready
}

enum SourceType {
  profile
  cv_upload
  linkedin
  background
  gap_answer
  manual
}

enum GapQuestionStatus {
  unanswered
  answered
  skipped
}

enum ButtonAnswer {
  yes
  kind_of
  no
  skip
}

enum AgentRunStatus {
  success
  error
  failed
}

enum PlanFamily {
  free
  pro
  premium
}

enum PlanVariant {
  free
  annual
  monthly
}

enum BillingSubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
  none
}

enum StripeWebhookProcessingStatus {
  processing
  processed
  failed
}

enum AbuseAction {
  account_create
  sign_in
  anonymous_analysis
  free_cv_claim
  checkout_create
  password_reset
  verification_resend
}

enum AbuseDecision {
  allowed
  throttled
  blocked
  flagged
}

model AnonymousSession {
  id                String             @id @default(cuid())
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")
  applications      Application[]
  candidateProfiles CandidateProfile[]

  @@map("anonymous_sessions")
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  emailVerified     Boolean             @default(false) @map("email_verified")
  name              String              @default("")
  image             String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at")
  sessions          Session[]
  accounts          Account[]
  billingAccount    BillingAccount?
  cvGenerationUsage CvGenerationUsage[]
  applications      Application[]
  candidateProfiles CandidateProfile[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

model Application {
  id                         String            @id @default(cuid())
  anonymousSessionId         String            @map("anonymous_session_id")
  userId                     String?           @map("user_id")
  status                     ApplicationStatus @default(started)
  currentStep                String            @default("started") @map("current_step")
  dreamRole                  String?           @map("dream_role")
  originalEvidenceMatchScore Float?            @map("original_evidence_match_score")
  updatedEvidenceMatchScore  Float?            @map("updated_evidence_match_score")
  matchLabel                 String?           @map("match_label")
  cvAngle                    String?           @map("cv_angle")
  roleArchetype              String?           @map("role_archetype")
  matchAnalysisJson          Json?             @map("match_analysis_json")
  createdAt                  DateTime          @default(now()) @map("created_at")
  updatedAt                  DateTime          @default(now()) @updatedAt @map("updated_at")

  anonymousSession        AnonymousSession    @relation(fields: [anonymousSessionId], references: [id], onDelete: Cascade)
  user                    User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  job                     Job?
  sourceCandidateProfiles CandidateProfile[]  @relation("SourceApplicationCandidateProfiles")
  gapQuestions            GapQuestion[]
  gapAnswers              GapAnswer[]
  cvDrafts                CvDraft[]
  cvGenerationUsage       CvGenerationUsage[]
  agentRuns               AgentRun[]

  @@index([anonymousSessionId])
  @@index([userId])
  @@map("applications")
}

model Job {
  id            String      @id @default(cuid())
  applicationId String      @unique @map("application_id")
  rawText       String      @map("raw_text") @db.Text
  title         String
  company       String?
  seniority     String?
  summary       String      @db.Text
  roleDomain    String?     @map("role_domain")
  archetypeHint String?     @map("archetype_hint")
  createdAt     DateTime    @default(now()) @map("created_at")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("jobs")
}

model CandidateProfile {
  id                        String            @id @default(cuid())
  anonymousSessionId        String?           @map("anonymous_session_id")
  userId                    String?           @map("user_id")
  sourceApplicationId       String?           @map("source_application_id")
  rawCvText                 String?           @map("raw_cv_text") @db.Text
  rawBackgroundText         String?           @map("raw_background_text") @db.Text
  contactInfoJson           Json?             @map("contact_info_json")
  linksJson                 Json?             @map("links_json")
  sourceType                SourceType?       @map("source_type")
  profileSource             String?           @map("profile_source")
  sourceSummary             String?           @map("source_summary") @db.Text
  sourceUrl                 String?           @map("source_url")
  sourceKey                 String?           @map("source_key")
  sourceHash                String?           @map("source_hash")
  contentHash               String?           @map("content_hash")
  profileConfirmedAt        DateTime?         @map("profile_confirmed_at")
  summary                   String            @db.Text
  skillsJson                Json              @map("skills_json")
  projectsJson              Json              @map("projects_json")
  educationJson             Json              @map("education_json")
  certificationsJson        Json              @map("certifications_json")
  experienceJson            Json              @map("experience_json")
  toolsJson                 Json              @map("tools_json")
  achievementsJson          Json              @map("achievements_json")
  cautionNotesJson          Json?             @map("caution_notes_json")
  metricOpportunitiesJson   Json?             @map("metric_opportunities_json")
  strongProofCandidatesJson Json?             @map("strong_proof_candidates_json")
  scopeOpportunitiesJson    Json?             @map("scope_opportunities_json")
  likelyTopEvidenceJson     Json?             @map("likely_top_evidence_json")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @default(now()) @updatedAt @map("updated_at")
  lastSeenAt                DateTime          @default(now()) @map("last_seen_at")
  archivedAt                DateTime?         @map("archived_at")
  anonymousSession          AnonymousSession? @relation(fields: [anonymousSessionId], references: [id], onDelete: SetNull)
  user                      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  sourceApplication         Application?      @relation("SourceApplicationCandidateProfiles", fields: [sourceApplicationId], references: [id], onDelete: SetNull)

  @@index([anonymousSessionId])
  @@index([userId])
  @@index([sourceApplicationId])
  @@index([sourceKey])
  @@index([contentHash])
  @@map("candidate_profiles")
}

model GapQuestion {
  id                String            @id @default(cuid())
  applicationId     String            @map("application_id")
  question          String            @db.Text
  reason            String            @db.Text
  whyItMatters      String?           @map("why_it_matters") @db.Text
  answerGuidance    String?           @map("answer_guidance") @db.Text
  exampleAnglesJson Json?             @map("example_angles_json")
  questionJson      Json?             @map("question_json")
  status            GapQuestionStatus @default(unanswered)
  createdAt         DateTime          @default(now()) @map("created_at")
  application       Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  answers           GapAnswer[]

  @@index([applicationId])
  @@map("gap_questions")
}

model GapAnswer {
  id                       String       @id @default(cuid())
  gapQuestionId            String       @map("gap_question_id")
  applicationId            String       @map("application_id")
  userId                   String?      @map("user_id")
  buttonAnswer             ButtonAnswer @map("button_answer")
  elaboration              String?      @db.Text
  selectedOption           String?      @map("selected_option")
  followUpText             String?      @map("follow_up_text") @db.Text
  metricText               String?      @map("metric_text") @db.Text
  rawUserAnswer            String?      @map("raw_user_answer") @db.Text
  extractedEvidenceSummary String?      @map("extracted_evidence_summary") @db.Text
  originalQuestion         String?      @map("original_question") @db.Text
  usableStatus             String?      @map("usable_status")
  evidenceQuality          String?      @map("evidence_quality")
  boostPercent             Int?         @map("boost_percent")
  source                   String?
  skipped                  Boolean      @default(false)
  createdAt                DateTime     @default(now()) @map("created_at")
  gapQuestion              GapQuestion  @relation(fields: [gapQuestionId], references: [id], onDelete: Cascade)
  application              Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([gapQuestionId])
  @@index([userId])
  @@map("gap_answers")
}

model CvDraft {
  id                String              @id @default(cuid())
  applicationId     String              @map("application_id")
  version           Int                 @default(1)
  cvJson            Json                @map("cv_json")
  cvText            String              @map("cv_text") @db.Text
  presentationJson  Json?               @map("presentation_json")
  builderOutputJson Json?               @map("builder_output_json")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at")
  application       Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  usage             CvGenerationUsage[]

  @@index([applicationId])
  @@map("cv_drafts")
}

model BillingAccount {
  id                           String                    @id @default(cuid())
  userId                       String                    @unique @map("user_id")
  stripeCustomerId             String?                   @unique @map("stripe_customer_id")
  stripeSubscriptionId         String?                   @unique @map("stripe_subscription_id")
  stripeSubscriptionScheduleId String?                   @unique @map("stripe_subscription_schedule_id")
  activePlanKey                String                    @default("free") @map("active_plan_key")
  planFamily                   PlanFamily                @default(free) @map("plan_family")
  planVariant                  PlanVariant               @default(free) @map("plan_variant")
  subscriptionStatus           BillingSubscriptionStatus @default(none) @map("subscription_status")
  priceId                      String?                   @map("price_id")
  currentPeriodStart           DateTime?                 @map("current_period_start")
  currentPeriodEnd             DateTime?                 @map("current_period_end")
  cancelAtPeriodEnd            Boolean                   @default(false) @map("cancel_at_period_end")
  commitmentStartAt            DateTime?                 @map("commitment_start_at")
  commitmentEndAt              DateTime?                 @map("commitment_end_at")
  commitmentActive             Boolean                   @default(false) @map("commitment_active")
  quotaPerPeriod               Int                       @default(1) @map("quota_per_period")
  lastSyncedAt                 DateTime?                 @map("last_synced_at")
  createdAt                    DateTime                  @default(now()) @map("created_at")
  updatedAt                    DateTime                  @updatedAt @map("updated_at")
  user                         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([activePlanKey])
  @@map("billing_accounts")
}

model CvGenerationUsage {
  id                 String      @id @default(cuid())
  userId             String      @map("user_id")
  applicationId      String      @map("application_id")
  cvDraftId          String?     @map("cv_draft_id")
  planKey            String      @map("plan_key")
  billingPeriodStart DateTime?   @map("billing_period_start")
  billingPeriodEnd   DateTime?   @map("billing_period_end")
  createdAt          DateTime    @default(now()) @map("created_at")
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application        Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  cvDraft            CvDraft?    @relation(fields: [cvDraftId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, billingPeriodStart, billingPeriodEnd])
  @@index([applicationId])
  @@index([cvDraftId])
  @@map("cv_generation_usage")
}

model StripeWebhookEvent {
  id               String                        @id @default(cuid())
  stripeEventId    String                        @unique @map("stripe_event_id")
  eventType        String                        @map("event_type")
  processedAt      DateTime?                     @map("processed_at")
  processingStatus StripeWebhookProcessingStatus @default(processing) @map("processing_status")
  error            String?                       @db.Text
  payloadHash      String?                       @map("payload_hash")
  createdAt        DateTime                      @default(now()) @map("created_at")
  updatedAt        DateTime                      @updatedAt @map("updated_at")

  @@index([eventType])
  @@index([processingStatus])
  @@map("stripe_webhook_events")
}

model AbuseSignalEvent {
  id                 String        @id @default(cuid())
  action             AbuseAction
  decision           AbuseDecision @default(allowed)
  userId             String?       @map("user_id")
  anonymousSessionId String?       @map("anonymous_session_id")
  deviceKeyHash      String?       @map("device_key_hash")
  ipKeyHash          String?       @map("ip_key_hash")
  metadataJson       Json?         @map("metadata_json")
  createdAt          DateTime      @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([userId, action, createdAt])
  @@index([anonymousSessionId, action, createdAt])
  @@index([deviceKeyHash, action, createdAt])
  @@index([ipKeyHash, action, createdAt])
  @@map("abuse_signal_events")
}

model AgentRun {
  id            String         @id @default(cuid())
  applicationId String         @map("application_id")
  agentName     String         @map("agent_name")
  inputSummary  String         @map("input_summary") @db.Text
  outputSummary String         @map("output_summary") @db.Text
  status        AgentRunStatus
  error         String?        @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("agent_runs")
}
