# Copy this file to `.env` for local development.

# Required app variables
DATABASE_URL="postgresql://postgres:password@localhost:5433/tailorcv"
BETTER_AUTH_SECRET="replace-with-at-least-32-characters-for-local-dev"
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
USE_MOCK_AI="true"

# Optional Google OAuth provider for sign-up/sign-in
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional email delivery for magic links
ENABLE_EMAIL="false"
RESEND_API_KEY=""
AUTH_EMAIL_FROM="TaylorCV <hello@your-domain.com>"

# Required when USE_MOCK_AI="false"
OPENAI_API_KEY=""
OPENAI_PROFILE_MODEL="gpt-5.4-nano"
OPENAI_JOB_MODEL="gpt-5.4-nano"
OPENAI_QUESTIONS_MODEL="gpt-5.4-nano"
OPENAI_WRITER_MODEL="gpt-5.5"
